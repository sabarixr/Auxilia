# Auxilia Backend Configuration
# Copy this file to .env and fill in your API keys

# App
APP_NAME=Auxilia API
APP_VERSION=1.0.0
DEBUG=true

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./auxilia.db

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# External APIs - Get your keys from:
# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key

# TomTom: https://developer.tomtom.com
TOMTOM_API_KEY=your-tomtom-api-key

# NewsAPI: https://newsapi.org
NEWS_API_KEY=your-newsapi-key

# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Blockchain (Local Hardhat - no keys needed for development)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=
WALLET_PRIVATE_KEY=

# Trigger Thresholds
RAIN_THRESHOLD_MM=50.0
TRAFFIC_THRESHOLD_PERCENT=60.0
SURGE_THRESHOLD_MULTIPLIER=2.5
ROAD_DISRUPTION_THRESHOLD_COUNT=3

# Payout Amounts (INR)
RAIN_PAYOUT=150
TRAFFIC_PAYOUT=100
SURGE_PAYOUT=200
ROAD_DISRUPTION_PAYOUT=500

# Zone Configuration
DEFAULT_CITY=Mumbai
DEFAULT_COUNTRY=IN
